{
  "name": "trip-sync-api",
  "version": "1.0.0",
  "description": "TripSync REST API — senior backend portfolio (Fastify, Prisma, schema-first)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "docs:check": "node scripts/check-openapi.mjs"
  },
  "author": "Kaique Rocha",
  "license": "MIT",
  "engines": { "node": ">=20" },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^6.3.1",
    "@trip-sync/contracts": "github:kaiqueRoc/trip-sync-contracts",
    "fastify": "^5.2.1",
    "fastify-type-provider-zod": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
